```typescript
describe("§13 Pipeline Requirements", () => {
  
  test("Multiple AIK timestamps → Multiple segments", async () => {
    const video = {
      title: "Fotbollsmorgon",
      full_description: "43:01 Erik Flataker om AIK\n1:02:35 Noa Bachner om AIK"
    };
    
    const result = await transform(video);
    
    expect(result.segments).toHaveLength(2);
    expect(result.segments[0].keyword_timestamp).toBe("43:01");
    expect(result.segments[1].keyword_timestamp).toBe("1:02:35");
    expect(result.segments[0].keyword_timestamp_description).toContain("Erik Flataker");
    expect(result.segments[0].keyword_timestamp_description).not.toBe(video.title);
  });
  
  test("No timestamps → Single default segment at 00:00:00", async () => {
    const video = {
      title: "AIK:s ALLA MÅL I ALLSVENSKAN 2025",
      full_description: "Alla målen från vårat lag."
    };
    
    const result = await transform(video);
    
    expect(result.segments).toHaveLength(1);
    expect(result.segments[0].keyword_timestamp).toBe("00:00:00");
    expect(result.segments[0].keyword_timestamp_seconds).toBe(0);
  });
  
  test("Timestamps exist but no direct AIK → AI validation", async () => {
    const video = {
      title: "Flatakers syn på säsongen i AIK",
      full_description: "43:01 Erik Flataker\n59:34 Reklampaus"
    };
    
    const result = await transform(video, { aiEnabled: true });
    
    // AI should validate "43:01 Erik Flataker" as AIK-relevant based on title context
    expect(result.segments.length).toBeGreaterThanOrEqual(1);
    expect(result.segments.some(s => s.keyword_timestamp === "43:01")).toBe(true);
  });
  
  test("Title NEVER used as keyword_timestamp_description fallback", async () => {
    const video = {
      title: "Test Video Title",
      full_description: "No timestamps here, just description text."
    };
    
    const result = await transform(video);
    
    // Even for default segment, description should NOT be the title
    expect(result.segments[0].keyword_timestamp_description).not.toBe(video.title);
  });
  
  test("minViews filtering disabled (accepts all view counts)", async () => {
    const videoLowViews = { view_count: 5, title: "AIK video" };
    const videoHighViews = { view_count: 100000, title: "AIK video" };
    
    const result1 = await fetch(videoLowViews);
    const result2 = await fetch(videoHighViews);
    
    // Both should be accepted
    expect(result1.accepted).toBe(true);
    expect(result2.accepted).toBe(true);
  });
});
```


##### 13.5.2.3 Channel Categorization (NEW 2026-01-12)
```typescript
// Compute channel_category for HomeTab segmentation
function getChannelCategory(channelTitle: string): string {
  const MATCH_CHANNELS = ['AIK Highlights', 'HockeyAllsvenskan', 'AIK Fotboll'];
  const MEDIA_CHANNELS = ['Fotbollsmorgon', 'TV4Sport', 'Studio Allsvenskan', 'DobbTV Fotboll', 'TuttoSvenskan', 'Sportstudion'];
  const VIRAL_CHANNELS = ['Swedish Ultras', 'SVENSK SUPPORTERKULTUR', 'Joakim Hall', 'Hungarian Football Vlogger', 'all about ultras', 'AIK Updates'];
  
  if (MATCH_CHANNELS.some(ch => channelTitle.includes(ch))) return 'match';
  if (MEDIA_CHANNELS.some(ch => channelTitle.includes(ch))) return 'media';
  if (VIRAL_CHANNELS.some(ch => channelTitle.includes(ch))) return 'viral';
  return 'other';
}

// Store in operational + segments tables for HomeTab filtering
await rpc('save_operational_video', { 
  ...params, 
  p_channel_category: getChannelCategory(video.channel_title) 
});
```

**Categories:**
- **match:** Highlights and match reports (AIK Highlights, HockeyAllsvenskan)
- **media:** Magazine shows and podcasts (Fotbollsmorgon, TV4Sport)
- **viral:** Supporter content and viral clips (Swedish Ultras, SVENSK SUPPORTERKULTUR)
- **other:** Unclassified content

##### 13.5.2.3 Segment Extraction Logic

**Scenario A: Timestamps Found**
```typescript
const timestamps = full_description.match(/\d{1,2}:\d{2}(?::\d{2})?/g);

if (timestamps && timestamps.length > 0) {
  // Phase 1: Direct keyword check
  for (const timestamp of timestamps) {
    const textAfter = extractTextBetween(timestamp, nextTimestamp);
    
    // Check 1: Direct keyword match in segment text
    if (/\b(AIK|Gnaget|AIK:s|AIKs|AIKare)\b/i.test(textAfter)) {
      createSegment(timestamp, textAfter); // ✅ ACCEPT
      continue;
    }
    
    // Check 2: Title Context Match (for compilation videos)
    // If video title is like "Player X on AIK | Other Topic", match segment text to "Player X"
    if (matchesTitleContext(textAfter, video.title, ["AIK", "Gnaget"])) {
      createSegment(timestamp, textAfter); // ✅ ACCEPT via Context
    }
  }
  
  // If Phase 1 found 0 segments → Phase 2: AI validation
  if (segments.length === 0 && titleMentionsAIK) {
    const aiSegments = await extractSegmentsWithAI(title, full_description, captions);
    segments.push(...aiSegments);
  }
  
  // If still 0 → fallback to default
  if (segments.length === 0) {
    createDefaultSegment('00:00:00', title);
  }
}
```

**Scenario B: No Timestamps**
```typescript
if (!timestamps || timestamps.length === 0) {
  // Entire video is AIK-relevant (keyword in title/metadata)
  createDefaultSegment('00:00:00', title);
}
```


### 13.3 Field Contracts (TypeScript Interface Specification)

#### 13.3.1 FETCH Layer Contract

```typescript
// Output: Records in youtube_videos_staging
interface FetchOutput {
  youtube_video_id: string;         // Primary identifier
  title: string;                    // Video title
  description: string;               // Truncated (~150 chars) for display
  full_description: string;          // COMPLETE YouTube description (CRITICAL)
  channel_title: string;
  published_at: timestamptz;
  view_count: bigint;                // NO filtering by this field
  like_count: bigint;                // NO filtering by this field
  duration: string;                  // ISO 8601 format (e.g., "PT12M34S")
  region_code: string;               // ISO 3166-1 alpha-2
  // ... other metadata
}

// CRITICAL VALIDATIONS:
// âœ… full_description.length >= description.length
// âœ… full_description !== title
// âœ… full_description contains actual YouTube description content
// âŒ NEVER: full_description = '' (empty)
// âŒ NEVER: full_description = description (truncated)
```

#### 13.3.2 TRANSFORM Layer Contract

```typescript
// Input: youtube_videos_staging records
// Output: Operational video (header) + Segments (line items)
interface TransformOutput {
  operational: OperationalVideo;    // 1 header record
  segments: VideoSegment[];         // 0 to N line item records
}

// Invariants (ALWAYS TRUE):
// - segments.length >= 0
// - If timestamps exist AND keyword found â†’ segments.length >= 1
// - If no timestamps â†’ segments.length === 1 (default at 00:00:00)
// - All segments reference same operational_video_id
// - Each segment has unique keyword_timestamp within same video
```

#### 13.3.3 Segment Field Specification

```typescript
interface VideoSegment {
  // Timestamp fields (dual format: text + seconds)
  keyword_timestamp: string;               // "1:23" format (TEXT for YouTube URLs)
  keyword_timestamp_seconds: number;       // 83 (INTEGER for calculations/sorting)
  
  // Description fields
  keyword_timestamp_description: string;   // Text extracted from full_description
  // CRITICAL: MUST be extracted text between timestamps
  // âŒ WRONG: keyword_timestamp_description = title (fallback)
  // âœ… RIGHT: keyword_timestamp_description = extractTextAfterTimestamp(full_description, timestamp)
  
  segment_description: string;             // Can be same as keyword_timestamp_description
  
  // Segment boundaries
  segment_start_seconds: number;           // = keyword_timestamp_seconds
  segment_end_seconds: number | null;      // Next timestamp or null (end of video)
  
  // Deep link (final product)
  youtube_deep_link: string;               // "https://youtube.com/watch?v=ID&t=83s"
  // Formula: `${base_url}?v=${youtube_video_id}&t=${keyword_timestamp_seconds}s`
  
  // Denormalized fields (from operational video)
  video_title: string;
  video_channel_title: string;
  video_published_at: timestamptz;
  video_region: string;
  view_count: bigint;
  like_count: bigint;
  sport_category: string;                  // 'football' | 'hockey' | null
}
```

